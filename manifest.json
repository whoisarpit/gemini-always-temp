{
  "manifest_version": 2,
  "name": "Gemini Always Temporary Chat",
  "version": "1.0",
  "description": "Automatically enables temporary chat when opening Gemini.",
  "permissions": ["storage"],
  "browser_action": {
    "default_icon": {
      "48": "icon-grey.svg"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.svg"
  }
}
